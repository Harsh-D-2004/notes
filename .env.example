# Set to "develop" to use local DB, set to "prod" to use Render DB
ENV=develop

# Local PostgreSQL connection string (used when ENV=develop)
DATABASE_URL_DEV=postgresql://localhost:5432/notesdb_dev

# Render PostgreSQL connection string (used when ENV=prod)
DATABASE_URL_PROD=postgresql://<user>:<password>@<host>/<db>

# Secret key used to sign and verify JWT tokens — use a long random string
JWT_SECRET=your-secret-key-here

# Port the server listens on
PORT=8000
